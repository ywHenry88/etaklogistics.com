---
import type { ImageMetadata } from "astro";

import SiteFooter from "../components/SiteFooter.astro";
import SiteHeader from "../components/SiteHeader.astro";
import "../styles/global.css";
import {
  brand,
  homeHref,
  pageHref,
  pageLabel,
  switchLanguage,
  type Lang,
  type PageKey,
  type SitePageKey,
} from "../data/site";

interface Props {
  lang: Lang;
  title: string;
  description: string;
  currentPage: SitePageKey;
  ogImage?: ImageMetadata;
}

const { lang, title, description, currentPage, ogImage } = Astro.props;
const alternateLang = switchLanguage(lang);
const siteUrl = Astro.site ?? "https://etaklogistics.com";
const canonicalPath =
  currentPage === "home" ? homeHref(lang) : pageHref(lang, currentPage);
const alternatePath =
  currentPage === "home" ? homeHref(alternateLang) : pageHref(alternateLang, currentPage);
const canonicalUrl = new URL(canonicalPath, siteUrl);
const alternateUrl = new URL(alternatePath, siteUrl);
const ogImageUrl = ogImage
  ? new URL(ogImage.src, siteUrl)
  : undefined;
const locale = lang === "zh" ? "zh-Hant-HK" : "en-HK";
const alternateLocale = alternateLang === "zh" ? "zh-Hant-HK" : "en-HK";
const ogLocale = lang === "zh" ? "zh_HK" : "en_HK";
const alternateOgLocale = alternateLang === "zh" ? "zh_HK" : "en_HK";
const siteRootUrl = new URL("/", siteUrl);
const normalizedAddress = brand.address.en.replace(/\s+/g, " ").trim();

const organizationSchema = {
  "@type": "Organization",
  name: brand.legalName,
  alternateName: brand.shortName[lang],
  url: siteRootUrl.toString(),
  telephone: brand.phone,
  faxNumber: brand.fax,
  email: brand.email,
  areaServed: "Hong Kong",
  address: {
    "@type": "PostalAddress",
    streetAddress: normalizedAddress,
    addressLocality: "Kwai Chung",
    addressRegion: "New Territories",
    addressCountry: "HK",
  },
  contactPoint: {
    "@type": "ContactPoint",
    contactType: "sales",
    telephone: brand.phone,
    email: brand.email,
    areaServed: "HK",
    availableLanguage: ["en", "zh-Hant"],
  },
};

const pageSchema =
  currentPage === "home"
    ? {
        "@type": "WebSite",
        name: brand.siteName,
        url: siteRootUrl.toString(),
        inLanguage: locale,
        description,
        publisher: {
          "@type": "Organization",
          name: brand.legalName,
        },
      }
    : {
        "@type": "WebPage",
        name: title,
        url: canonicalUrl.toString(),
        inLanguage: locale,
        description,
        isPartOf: {
          "@type": "WebSite",
          name: brand.siteName,
          url: siteRootUrl.toString(),
        },
        about: {
          "@type": "Organization",
          name: brand.legalName,
        },
      };

const breadcrumbSchema =
  currentPage === "home"
    ? null
    : {
        "@type": "BreadcrumbList",
        itemListElement: [
          {
            "@type": "ListItem",
            position: 1,
            name: lang === "zh" ? "首頁" : "Home",
            item: new URL(homeHref(lang), siteUrl).toString(),
          },
          {
            "@type": "ListItem",
            position: 2,
            name: pageLabel(lang, currentPage as PageKey),
            item: canonicalUrl.toString(),
          },
        ],
      };

const structuredData = JSON.stringify(
  {
    "@context": "https://schema.org",
    "@graph": breadcrumbSchema
      ? [organizationSchema, pageSchema, breadcrumbSchema]
      : [organizationSchema, pageSchema],
  },
  null,
  2,
);
---

<!doctype html>
<html lang={locale}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="robots" content="index,follow" />
    <link rel="canonical" href={canonicalUrl} />
    <link rel="alternate" hreflang={locale} href={canonicalUrl} />
    <link
      rel="alternate"
      hreflang={alternateLocale}
      href={alternateUrl}
    />
    <link rel="alternate" hreflang="x-default" href={siteRootUrl} />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content={brand.siteName} />
    <meta property="og:locale" content={ogLocale} />
    <meta property="og:locale:alternate" content={alternateOgLocale} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    {ogImageUrl && <meta property="og:image" content={ogImageUrl} />}
    {ogImageUrl && <meta property="og:image:alt" content={title} />}
    {ogImage && <meta property="og:image:width" content={String(ogImage.width)} />}
    {ogImage && <meta property="og:image:height" content={String(ogImage.height)} />}
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    {ogImageUrl && <meta name="twitter:image" content={ogImageUrl} />}
    <script type="application/ld+json" set:html={structuredData}></script>
  </head>
  <body class="enterprise-site-body bg-[var(--color-bg)] text-[var(--color-ink)]">
    <div class="site-shell enterprise-site-shell">
      <SiteHeader lang={lang} currentPage={currentPage} />
      <main class="enterprise-site-main">
        <slot />
      </main>
      <SiteFooter lang={lang} />
    </div>
    <script is:inline>
      const root = document.documentElement;
      root.classList.add("page-ready");

      const revealItems = Array.from(document.querySelectorAll("[data-reveal]"));
      const markVisible = (element) => {
        element.classList.add("is-visible");
      };

      revealItems
        .filter((element) => element.getBoundingClientRect().top < window.innerHeight * 0.92)
        .forEach(markVisible);

      const observer = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              markVisible(entry.target);
              observer.unobserve(entry.target);
            }
          });
        },
        { threshold: 0.16, rootMargin: "0px 0px -40px 0px" },
      );

      revealItems.forEach((element) => observer.observe(element));

      window.setTimeout(() => {
        revealItems.forEach(markVisible);
      }, 1800);
    </script>
  </body>
</html>
